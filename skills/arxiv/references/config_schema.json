{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "arXiv Search Request",
  "description": "Schema for arXiv paper search and download requests, optimized for LLM parsing",
  "type": "object",
  "properties": {
    "query": {
      "description": "Search query (arXivQL string or structured terms)",
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "description": "arXivQL search string (e.g., 'ti:quantum AND au:smith')",
          "examples": [
            "quantum machine learning",
            "ti:attention AND au:shaw",
            "abs:deep learning submittedDate:[20200101 TO 20241231]"
          ]
        },
        {
          "type": "array",
          "minItems": 1,
          "description": "Structured search terms",
          "items": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string",
                "enum": ["title", "author", "abstract", "comment", "journal", "category", "report_number", "all"],
                "description": "Search field: title, author, abstract, comment, journal, category, or all",
                "examples": ["title", "author", "abstract", "category"]
              },
              "value": {
                "type": "string",
                "minLength": 1,
                "description": "Search term value"
              }
            },
            "required": ["field", "value"],
            "additionalProperties": false
          },
          "examples": [
            [{"field": "title", "value": "quantum"}]
          ]
        }
      ]
    },
    "id_list": {
      "description": "Comma-separated arXiv IDs to fetch (optional, filters query if both provided). Example: '1605.08386,2107.05580v1'",
      "type": "string",
      "pattern": "^\\d{4}\\.\\d{4,5}(v\\d+)?(,\\s*\\d{4}\\.\\d{4,5}(v\\d+)?)+$",
      "examples": ["1605.08386", "2107.05580v1,1801.00004", "2201.00001, 2201.00002, 2201.00003"]
    },
    "max_results": {
      "description": "Maximum papers to retrieve",
      "type": "integer",
      "minimum": 1,
      "maximum": 30000,
      "default": 100,
      "examples": [10, 100, 500]
    },
    "sort_by": {
      "description": "Sort criterion",
      "type": "string",
      "enum": ["Relevance", "LastUpdatedDate", "SubmittedDate"],
      "default": "Relevance",
      "examples": ["SubmittedDate"]
    },
    "sort_order": {
      "description": "Sort direction",
      "type": "string",
      "enum": ["Ascending", "Descending"],
      "default": "Descending"
    },
    "client": {
      "description": "Client configuration",
      "type": "object",
      "properties": {
        "page_size": {
          "description": "API page size",
          "type": "integer",
          "minimum": 1,
          "maximum": 2000,
          "default": 100
        },
        "delay_seconds": {
          "description": "Seconds between requests (arXiv recommends <= 3s)",
          "type": "number",
          "minimum": 0,
          "default": 3.0
        },
        "num_retries": {
          "description": "Retry count on failure",
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "default": 3
        }
      },
      "additionalProperties": false
    },
    "output_dir": {
      "description": "Directory to download papers to",
      "type": "string",
      "default": "./arxiv/"
    },
    "page_size": {
      "description": "Number of results per API request (1-2000)",
      "type": "integer",
      "minimum": 1,
      "maximum": 2000,
      "default": 100
    },
    "delay_seconds": {
      "description": "Delay between requests in seconds",
      "type": "number",
      "minimum": 0,
      "default": 3.0
    },
    "num_retries": {
      "description": "Number of retry attempts per request",
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "default": 3
    },
    "search": {
      "description": "Search parameters",
      "type": "object",
      "properties": {
        "query": {
          "description": "Search query (arXivQL string or structured terms)",
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "description": "arXivQL search string",
              "examples": ["quantum machine learning", "ti:attention AND au:shaw"]
            },
            {
              "type": "array",
              "minItems": 1,
              "description": "Structured search terms",
              "items": {
                "type": "object",
                "properties": {
                  "field": {
                    "type": "string",
                    "enum": ["title", "author", "abstract", "comment", "journal", "category", "report_number", "all"],
                    "description": "Search field"
                  },
                  "value": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Search term value"
                  }
                },
                "required": ["field", "value"]
              }
            }
          ]
        },
        "max_results": {
          "description": "Maximum number of results (1-300000)",
          "type": "integer",
          "minimum": 1,
          "maximum": 300000,
          "default": null
        },
        "sort_by": {
          "description": "Sort criterion",
          "type": "string",
          "default": "relevance",
          "enum": ["relevance", "lastUpdatedDate", "submittedDate"]
        },
        "sort_order": {
          "description": "Sort order",
          "type": "string",
          "default": "descending",
          "enum": ["ascending", "descending"]
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["query"],
  "additionalProperties": false
}
